# Required: get one at https://www.voyageai.com/
VOYAGE_API_KEY=

# Optional: how many top matches the on_prompt hook injects
TOP_K=5

# Optional: minimum cosine similarity (0–1) for a match to be injected
MIN_SCORE=0.3

# Optional: override the data directory (default: ~/.claude/claude-memory)
# CLAUDE_MEMORY_DIR=

# Optional: model used for end-of-session summaries
# CLAUDE_MEMORY_SUMMARY_MODEL=claude-haiku-4-5-20251001
